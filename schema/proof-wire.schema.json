{
  "$defs": {
    "AcceptanceThresholds": {
      "description": "Declared thresholds a run must clear to be accepted (the CI gate, #12).\n\nTurns \"was this LoRA/dataset good enough?\" into an automatable yes/no. Only\nthe configured checks run; leave a field ``None`` to skip it.\n``min_pass_rate_ci_lower`` is the stricter, small-N-safe version of\n``min_pass_rate`` \u2014 the Wilson lower bound must clear it, so a lucky 3/3\ndoesn't pass a bar that 300/400 would.",
      "properties": {
        "confidence": {
          "default": 0.95,
          "exclusiveMaximum": 1.0,
          "exclusiveMinimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "max_unsafe_rate": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Unsafe Rate"
        },
        "min_identity_mean": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Min Identity Mean"
        },
        "min_pass_rate": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": 0.75,
          "title": "Min Pass Rate"
        },
        "min_pass_rate_ci_lower": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Min Pass Rate Ci Lower"
        }
      },
      "title": "AcceptanceThresholds",
      "type": "object"
    },
    "AggregateScores": {
      "description": "Run-level roll-up: counts, pass rate, mean of each metric axis, diversity.\n\n``pass_rate`` is computed over near-duplicate *groups*, not raw frames, so a\ncluster of Monte-Carlo near-dups counts once: ``n_passed / n_groups``.\n``n_groups`` equals ``n_images`` when no deduper ran.",
      "properties": {
        "diversity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Diversity"
        },
        "means": {
          "$ref": "#/$defs/MetricScores"
        },
        "n_groups": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "N Groups"
        },
        "n_images": {
          "minimum": 0,
          "title": "N Images",
          "type": "integer"
        },
        "n_needs_hitl": {
          "default": 0,
          "minimum": 0,
          "title": "N Needs Hitl",
          "type": "integer"
        },
        "n_passed": {
          "minimum": 0,
          "title": "N Passed",
          "type": "integer"
        },
        "pass_rate": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Pass Rate",
          "type": "number"
        }
      },
      "required": [
        "n_images",
        "n_passed",
        "pass_rate"
      ],
      "title": "AggregateScores",
      "type": "object"
    },
    "BackendCapabilities": {
      "description": "What a generation backend can do \u2014 its capability descriptor.\n\nLets a caller pick or validate a backend without hard-coding which one it\nis: swapping backends is a config change, not a code change.",
      "properties": {
        "max_loras": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Loras"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "reads_pnginfo": {
          "default": false,
          "title": "Reads Pnginfo",
          "type": "boolean"
        },
        "streams_progress": {
          "default": false,
          "title": "Streams Progress",
          "type": "boolean"
        },
        "supports_seed_set": {
          "default": true,
          "title": "Supports Seed Set",
          "type": "boolean"
        }
      },
      "required": [
        "name"
      ],
      "title": "BackendCapabilities",
      "type": "object"
    },
    "EvalReport": {
      "description": "Scored evaluation of a generation run: per-image + aggregate + verdict.\n\nLinks to its :class:`RunManifest` by ``run_id`` rather than embedding it, so\nthe run dir stays the single source of truth for generation params.",
      "properties": {
        "aggregate": {
          "$ref": "#/$defs/AggregateScores"
        },
        "created_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Created At"
        },
        "images": {
          "items": {
            "$ref": "#/$defs/ImageScores"
          },
          "title": "Images",
          "type": "array"
        },
        "proof_version": {
          "default": "1.0",
          "title": "Proof Version",
          "type": "string"
        },
        "run_id": {
          "title": "Run Id",
          "type": "string"
        },
        "scorers": {
          "items": {
            "$ref": "#/$defs/ScorerProvenance"
          },
          "title": "Scorers",
          "type": "array"
        },
        "verdict": {
          "$ref": "#/$defs/Verdict"
        }
      },
      "required": [
        "run_id",
        "aggregate",
        "verdict"
      ],
      "title": "EvalReport",
      "type": "object"
    },
    "GateCheck": {
      "description": "One threshold check's outcome, with the actual value vs the threshold.",
      "properties": {
        "actual": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Actual"
        },
        "detail": {
          "default": "",
          "title": "Detail",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "threshold": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Threshold"
        }
      },
      "required": [
        "name",
        "passed"
      ],
      "title": "GateCheck",
      "type": "object"
    },
    "GateConfig": {
      "description": "Thresholds that route each image to auto-pass / auto-fail / needs-HITL.\n\nAn automated pre-pass so humans only rate the borderline band (HITL doesn't\nscale to every image). Scorers return a normalised score in ``[0, 1]``\n(higher = better); the gate takes a ``weights``-weighted mean of the metrics\npresent (curator's weighted ``score_breakdown`` pattern) into a composite:\n``composite >= auto_pass`` \u2192 pass, ``<= auto_fail`` \u2192 fail, between \u2192 HITL.\n``hard_gates`` are absolute per-metric floors (e.g. a minimum identity) that\nfail an image regardless of composite. A run passes when its group pass-rate\nreaches ``run_pass_rate``.\n\n``safety`` is in the default composite weights so an unsafe image is dragged\ndown once safety scoring lands (Phase 4); for a true veto, add ``safety`` to\n``hard_gates`` with your scorer's floor \u2014 the composite alone can let a\nhigh-quality-but-unsafe image through.",
      "properties": {
        "auto_fail": {
          "default": 0.4,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Auto Fail",
          "type": "number"
        },
        "auto_pass": {
          "default": 0.7,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Auto Pass",
          "type": "number"
        },
        "hard_gates": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Hard Gates",
          "type": "object"
        },
        "run_pass_rate": {
          "default": 0.75,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Run Pass Rate",
          "type": "number"
        },
        "weights": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Weights",
          "type": "object"
        }
      },
      "title": "GateConfig",
      "type": "object"
    },
    "GateResult": {
      "description": "The overall accept/reject decision \u2014 ``passed`` iff every check passed.",
      "properties": {
        "checks": {
          "items": {
            "$ref": "#/$defs/GateCheck"
          },
          "title": "Checks",
          "type": "array"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        }
      },
      "required": [
        "passed"
      ],
      "title": "GateResult",
      "type": "object"
    },
    "GeneratedImage": {
      "description": "One image a backend produced, ready to be scored.\n\n``image_id`` is the opaque handle scores reference; ``(run_id, seed)`` is the\nreproducible key. ``pnginfo`` is the metadata read back from the PNG the\nengine embedded (ComfyUI PNGInfo), so the recorded params can be checked\nagainst what actually rendered rather than trusted blind.",
      "properties": {
        "height": {
          "title": "Height",
          "type": "integer"
        },
        "image_id": {
          "title": "Image Id",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "pnginfo": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Pnginfo",
          "type": "object"
        },
        "run_id": {
          "title": "Run Id",
          "type": "string"
        },
        "seed": {
          "title": "Seed",
          "type": "integer"
        },
        "width": {
          "title": "Width",
          "type": "integer"
        }
      },
      "required": [
        "image_id",
        "run_id",
        "seed",
        "path",
        "width",
        "height"
      ],
      "title": "GeneratedImage",
      "type": "object"
    },
    "GridConfig": {
      "description": "The axes that expand a source export into a grid of :class:`RunSpec`s.\n\nBase prompts come from the export's captions (the zeroshot caption variant,\nfalling back to the training ``.txt`` sidecar). Those are multiplied across\nthe axes below into a deterministic, reproducible set of runs; a control\n``seeds`` set is shared by every run so seed luck can't skew a comparison.\n\n* ``lora_checkpoints`` \u2014 the LoRA(s) to sweep; supply saved epoch checkpoints\n  here to find the under/overtrained sweet spot (cheap, no retrain).\n* ``lora_weights`` \u2014 the weight sweep (e.g. 0.6\u20131.0); optimal weight varies\n  per checkpoint and interacts with overtraining.\n* ``token_axes`` \u2014 variable tokens (setting/wardrobe/pose \u2026) combined into\n  Monte-Carlo combos appended to each base prompt, capped by\n  ``max_token_combos`` and sampled deterministically from ``combo_seed`` so\n  token effects stay attributable.\n* ``flexibility_prompts`` \u2014 off-distribution prompts that require a novel\n  attribute, to catch an overfit LoRA that only reproduces its training set.",
      "properties": {
        "base_checkpoint": {
          "title": "Base Checkpoint",
          "type": "string"
        },
        "combo_seed": {
          "default": 0,
          "title": "Combo Seed",
          "type": "integer"
        },
        "flexibility_prompts": {
          "items": {
            "type": "string"
          },
          "title": "Flexibility Prompts",
          "type": "array"
        },
        "lora_checkpoints": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Lora Checkpoints",
          "type": "array"
        },
        "lora_weights": {
          "items": {
            "type": "number"
          },
          "minItems": 1,
          "title": "Lora Weights",
          "type": "array"
        },
        "max_base_prompts": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Base Prompts"
        },
        "max_token_combos": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Token Combos"
        },
        "negative_prompt": {
          "default": "",
          "title": "Negative Prompt",
          "type": "string"
        },
        "run_id_prefix": {
          "default": "proof",
          "title": "Run Id Prefix",
          "type": "string"
        },
        "sampling": {
          "$ref": "#/$defs/SamplingParams"
        },
        "seconds_per_image": {
          "default": 6.0,
          "title": "Seconds Per Image",
          "type": "number"
        },
        "seeds": {
          "items": {
            "type": "integer"
          },
          "minItems": 1,
          "title": "Seeds",
          "type": "array"
        },
        "source_manifest": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Manifest"
        },
        "source_manifest_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Manifest Version"
        },
        "token_axes": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": "Token Axes",
          "type": "object"
        },
        "training_run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Training Run Id"
        }
      },
      "required": [
        "base_checkpoint",
        "lora_checkpoints",
        "sampling",
        "seeds"
      ],
      "title": "GridConfig",
      "type": "object"
    },
    "GridEstimate": {
      "description": "The up-front count + GPU-hour estimate reported before any generation.\n\n``axes`` breaks the grid down (how many checkpoints \u00d7 weights \u00d7 prompts \u00d7\nseeds) so a caller sees why the count is what it is before committing GPU.",
      "properties": {
        "axes": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Axes",
          "type": "object"
        },
        "est_gpu_hours": {
          "title": "Est Gpu Hours",
          "type": "number"
        },
        "est_gpu_seconds": {
          "title": "Est Gpu Seconds",
          "type": "number"
        },
        "n_images": {
          "title": "N Images",
          "type": "integer"
        },
        "n_runs": {
          "title": "N Runs",
          "type": "integer"
        },
        "seconds_per_image": {
          "title": "Seconds Per Image",
          "type": "number"
        }
      },
      "required": [
        "n_runs",
        "n_images",
        "seconds_per_image",
        "est_gpu_seconds",
        "est_gpu_hours"
      ],
      "title": "GridEstimate",
      "type": "object"
    },
    "GridPlan": {
      "description": "A fully enumerated grid: the runs to generate plus their cost estimate.",
      "properties": {
        "estimate": {
          "$ref": "#/$defs/GridEstimate"
        },
        "run_id_prefix": {
          "title": "Run Id Prefix",
          "type": "string"
        },
        "specs": {
          "items": {
            "$ref": "#/$defs/RunSpec"
          },
          "title": "Specs",
          "type": "array"
        }
      },
      "required": [
        "run_id_prefix",
        "estimate"
      ],
      "title": "GridPlan",
      "type": "object"
    },
    "ImageScores": {
      "description": "Per-image scores for one generated sample, keyed by ``(run_id, seed)``.\n\n``image_id`` is an opaque handle for the report to reference; the durable,\nreproducible key is ``seed`` (with the run's :class:`RunManifest`).\n``hitl_rating`` is a 1\u20135 star human rating when review has happened.",
      "properties": {
        "duplicate_group": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Duplicate Group"
        },
        "hitl_rating": {
          "anyOf": [
            {
              "maximum": 5,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hitl Rating"
        },
        "image_id": {
          "title": "Image Id",
          "type": "string"
        },
        "metrics": {
          "$ref": "#/$defs/MetricScores"
        },
        "passed": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Passed"
        },
        "reject_reasons": {
          "items": {
            "$ref": "#/$defs/RejectReason"
          },
          "title": "Reject Reasons",
          "type": "array"
        },
        "seed": {
          "title": "Seed",
          "type": "integer"
        }
      },
      "required": [
        "image_id",
        "seed"
      ],
      "title": "ImageScores",
      "type": "object"
    },
    "LoRARef": {
      "description": "A LoRA applied during generation, as recorded in a resolved run: a\n:class:`ModelRef` (name pinned by SHA256) plus its weight.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "sha256": {
          "description": "lowercase hex SHA256 digest",
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "weight": {
          "default": 1.0,
          "title": "Weight",
          "type": "number"
        }
      },
      "required": [
        "name",
        "sha256"
      ],
      "title": "LoRARef",
      "type": "object"
    },
    "LoRASpec": {
      "description": "A LoRA to apply, as *requested* \u2014 name + weight, before the file is hashed.\n\nThe request-time counterpart of :class:`LoRARef`: a :class:`RunSpec` names a\nLoRA by filename; the backend resolves it to a file, hashes it, and records\nthe resulting :class:`LoRARef` in the :class:`RunManifest`.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "weight": {
          "default": 1.0,
          "title": "Weight",
          "type": "number"
        }
      },
      "required": [
        "name"
      ],
      "title": "LoRASpec",
      "type": "object"
    },
    "MetricScores": {
      "description": "The scoring axes for one image (or their means, in the aggregate).\n\nEvery field is optional so an axis whose scorer did not run stays ``None``\ninstead of a misleading ``0.0``. Semantics: ``identity`` similarity to the\nreference (higher = closer), ``clip_score`` prompt adherence, ``aesthetic``\nan IQA/aesthetic score, ``preference`` an ImageReward/HPS-style score, and\n``safety`` a safety score.",
      "properties": {
        "aesthetic": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Aesthetic"
        },
        "clip_score": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Clip Score"
        },
        "identity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Identity"
        },
        "preference": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Preference"
        },
        "safety": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Safety"
        }
      },
      "title": "MetricScores",
      "type": "object"
    },
    "ModelRef": {
      "description": "A model file pinned by content: how the engine names it + its SHA256.\n\n``name`` is what the generation engine loads (e.g. a ComfyUI checkpoint\nfilename); ``sha256`` is the real identity, so a manifest can't drift if the\nfile behind the name changes.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "sha256": {
          "description": "lowercase hex SHA256 digest",
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "name",
        "sha256"
      ],
      "title": "ModelRef",
      "type": "object"
    },
    "ProgressEvent": {
      "description": "One NDJSON progress line streamed during generation (suite convention).\n\n``type`` selects which fields matter: ``start`` sets ``total`` (images to\nmake); ``progress`` sets ``completed``/``total``; ``image`` sets ``seed`` +\n``image_id`` as each finishes; ``done`` closes the run; ``error`` carries a\nfailure ``message``.",
      "properties": {
        "completed": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Completed"
        },
        "image_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Image Id"
        },
        "message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Message"
        },
        "run_id": {
          "title": "Run Id",
          "type": "string"
        },
        "seed": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Seed"
        },
        "total": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total"
        },
        "type": {
          "enum": [
            "start",
            "progress",
            "image",
            "done",
            "error"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "run_id",
        "type"
      ],
      "title": "ProgressEvent",
      "type": "object"
    },
    "RejectArchive": {
      "description": "Metadata-only archive of rejected/flagged outputs \u2014 zero image references.\n\n``manifests`` (keyed by ``run_id``) carries the full generation params for\nevery run a record came from, so the archive is self-describing: you can see\nexactly what produced a bad output without keeping the output itself. Both\n:class:`RunManifest` and :class:`RejectRecord` are image-free by\nconstruction, so the archive retains no image or thumbnail paths.",
      "properties": {
        "manifests": {
          "additionalProperties": {
            "$ref": "#/$defs/RunManifest"
          },
          "title": "Manifests",
